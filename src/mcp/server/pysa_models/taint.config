{
  "comment": "TEE-MCP: 11 security capability classes for tool authorization",
  "sources": [
    {
      "name": "ToolInput",
      "comment": "Data from MCP tool call arguments — the entry point for all tool operations"
    }
  ],
  "sinks": [
    {
      "name": "CodeExecution",
      "comment": "CRITICAL: Execute code, shell, subprocess, eval, Docker"
    },
    {
      "name": "CredentialAccess",
      "comment": "CRITICAL: Read/write credentials, tokens, passwords, API keys"
    },
    {
      "name": "IdentityAdmin",
      "comment": "CRITICAL: Manage users, permissions, roles, access sharing"
    },
    {
      "name": "CrossBoundaryEgress",
      "comment": "HIGH: Send data to external systems (email, HTTP POST, webhook)"
    },
    {
      "name": "ValueTransfer",
      "comment": "HIGH: Financial transactions, bookings, payments, refunds"
    },
    {
      "name": "DataDestruction",
      "comment": "HIGH: Delete email, files, records, accounts"
    },
    {
      "name": "ReadIdentity",
      "comment": "HIGH: Read PII, contacts, personal identifiers"
    },
    {
      "name": "WriteMutate",
      "comment": "MEDIUM: Create/update/modify records, files, events"
    },
    {
      "name": "ReadPrivate",
      "comment": "MEDIUM: Read private workspace data (email, calendar, files)"
    },
    {
      "name": "ExternalIngestion",
      "comment": "LOW: Fetch external URLs, scrape web content"
    },
    {
      "name": "ReadPublic",
      "comment": "LOW: Read publicly available data"
    }
  ],
  "rules": [
    {
      "name": "Code execution reachable from tool input",
      "code": 9001,
      "sources": ["ToolInput"],
      "sinks": ["CodeExecution"],
      "message_format": "Tool input flows to code execution sink: {$sinks}"
    },
    {
      "name": "Credential access reachable from tool input",
      "code": 9002,
      "sources": ["ToolInput"],
      "sinks": ["CredentialAccess"],
      "message_format": "Tool input flows to credential access: {$sinks}"
    },
    {
      "name": "Identity admin reachable from tool input",
      "code": 9003,
      "sources": ["ToolInput"],
      "sinks": ["IdentityAdmin"],
      "message_format": "Tool input flows to identity management: {$sinks}"
    },
    {
      "name": "Cross-boundary egress reachable from tool input",
      "code": 9004,
      "sources": ["ToolInput"],
      "sinks": ["CrossBoundaryEgress"],
      "message_format": "Tool input flows to external egress: {$sinks}"
    },
    {
      "name": "Value transfer reachable from tool input",
      "code": 9005,
      "sources": ["ToolInput"],
      "sinks": ["ValueTransfer"],
      "message_format": "Tool input flows to value transfer: {$sinks}"
    },
    {
      "name": "Data destruction reachable from tool input",
      "code": 9006,
      "sources": ["ToolInput"],
      "sinks": ["DataDestruction"],
      "message_format": "Tool input flows to data destruction: {$sinks}"
    },
    {
      "name": "PII read reachable from tool input",
      "code": 9007,
      "sources": ["ToolInput"],
      "sinks": ["ReadIdentity"],
      "message_format": "Tool input flows to PII access: {$sinks}"
    },
    {
      "name": "State mutation reachable from tool input",
      "code": 9008,
      "sources": ["ToolInput"],
      "sinks": ["WriteMutate"],
      "message_format": "Tool input flows to state mutation: {$sinks}"
    },
    {
      "name": "Private data read reachable from tool input",
      "code": 9009,
      "sources": ["ToolInput"],
      "sinks": ["ReadPrivate"],
      "message_format": "Tool input flows to private data read: {$sinks}"
    },
    {
      "name": "External ingestion reachable from tool input",
      "code": 9010,
      "sources": ["ToolInput"],
      "sinks": ["ExternalIngestion"],
      "message_format": "Tool input flows to external content ingestion: {$sinks}"
    },
    {
      "name": "Public data read reachable from tool input",
      "code": 9011,
      "sources": ["ToolInput"],
      "sinks": ["ReadPublic"],
      "message_format": "Tool input flows to public data read: {$sinks}"
    }
  ]
}
