{
  "comment": "TEE-MCP taint config for AgentDojo tool analysis",
  "sources": [
    {
      "name": "ToolInput",
      "comment": "Data from MCP tool call arguments"
    }
  ],
  "sinks": [
    {
      "name": "CodeExecution",
      "comment": "CRITICAL: Execute code, shell, subprocess, eval"
    },
    {
      "name": "CredentialAccess",
      "comment": "CRITICAL: Read/write credentials, tokens, passwords"
    },
    {
      "name": "IdentityAdmin",
      "comment": "CRITICAL: Manage users, permissions, roles"
    },
    {
      "name": "CrossBoundaryEgress",
      "comment": "HIGH: Send data to external systems"
    },
    {
      "name": "ValueTransfer",
      "comment": "HIGH: Financial transactions, bookings, payments"
    },
    {
      "name": "DataDestruction",
      "comment": "HIGH: Delete records, files, accounts"
    },
    {
      "name": "ReadIdentity",
      "comment": "HIGH: Read PII, contacts, personal identifiers"
    },
    {
      "name": "WriteMutate",
      "comment": "MEDIUM: Create/update/modify records, files, events"
    },
    {
      "name": "ReadPrivate",
      "comment": "MEDIUM: Read private workspace data"
    },
    {
      "name": "ExternalIngestion",
      "comment": "LOW: Fetch external URLs, scrape web content"
    },
    {
      "name": "ReadPublic",
      "comment": "LOW: Read publicly available data"
    }
  ],
  "rules": [
    {"name": "Code execution", "code": 9001, "sources": ["ToolInput"], "sinks": ["CodeExecution"], "message_format": "Tool input flows to code execution: {$sinks}"},
    {"name": "Credential access", "code": 9002, "sources": ["ToolInput"], "sinks": ["CredentialAccess"], "message_format": "Tool input flows to credential access: {$sinks}"},
    {"name": "Identity admin", "code": 9003, "sources": ["ToolInput"], "sinks": ["IdentityAdmin"], "message_format": "Tool input flows to identity management: {$sinks}"},
    {"name": "Cross-boundary egress", "code": 9004, "sources": ["ToolInput"], "sinks": ["CrossBoundaryEgress"], "message_format": "Tool input flows to external egress: {$sinks}"},
    {"name": "Value transfer", "code": 9005, "sources": ["ToolInput"], "sinks": ["ValueTransfer"], "message_format": "Tool input flows to value transfer: {$sinks}"},
    {"name": "Data destruction", "code": 9006, "sources": ["ToolInput"], "sinks": ["DataDestruction"], "message_format": "Tool input flows to data destruction: {$sinks}"},
    {"name": "PII read", "code": 9007, "sources": ["ToolInput"], "sinks": ["ReadIdentity"], "message_format": "Tool input flows to PII access: {$sinks}"},
    {"name": "State mutation", "code": 9008, "sources": ["ToolInput"], "sinks": ["WriteMutate"], "message_format": "Tool input flows to state mutation: {$sinks}"},
    {"name": "Private data read", "code": 9009, "sources": ["ToolInput"], "sinks": ["ReadPrivate"], "message_format": "Tool input flows to private data read: {$sinks}"},
    {"name": "External ingestion", "code": 9010, "sources": ["ToolInput"], "sinks": ["ExternalIngestion"], "message_format": "Tool input flows to external content ingestion: {$sinks}"},
    {"name": "Public data read", "code": 9011, "sources": ["ToolInput"], "sinks": ["ReadPublic"], "message_format": "Tool input flows to public data read: {$sinks}"}
  ]
}
