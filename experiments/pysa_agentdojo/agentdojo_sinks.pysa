# Pysa sink models for AgentDojo domain wrapper methods.
#
# Each wrapper method in domain_types.py corresponds to a C-extension
# mutation (list.append, dict.pop, etc.) that Pysa cannot trace.
# These models make the wrapper methods Pysa-visible sinks.

# ========== VALUE_TRANSFER ==========
def domain_types.Transaction.__init__(self, id, sender, recipient: TaintSink[ValueTransfer], amount: TaintSink[ValueTransfer], subject, date, recurring): ...
def domain_types.BankAccount.record_transaction(self, transaction: TaintSink[ValueTransfer]): ...
def domain_types.BankAccount.record_scheduled_transaction(self, transaction: TaintSink[ValueTransfer]): ...
def domain_types.BankAccount.update_scheduled_transaction_fields(self, transaction, recipient: TaintSink[ValueTransfer], amount: TaintSink[ValueTransfer], subject, date, recurring): ...
def domain_types.Reservation.book_hotel(self, hotel: TaintSink[ValueTransfer], start_day, end_day): ...
def domain_types.Reservation.book_restaurant(self, restaurant: TaintSink[ValueTransfer], start_time): ...
def domain_types.Reservation.book_car(self, company: TaintSink[ValueTransfer], start_time, end_time): ...

# ========== CROSS_BOUNDARY_EGRESS ==========
def domain_types.Inbox.dispatch_email(self, recipients: TaintSink[CrossBoundaryEgress], subject, body: TaintSink[CrossBoundaryEgress], cc, bcc, attachments): ...
def domain_types.Email.__init__(self, id_, sender, body: TaintSink[CrossBoundaryEgress], subject, recipients: TaintSink[CrossBoundaryEgress], status, timestamp, cc, bcc, attachments, read): ...
def domain_types.Slack.deliver_direct_message(self, sender, recipient: TaintSink[CrossBoundaryEgress], body: TaintSink[CrossBoundaryEgress]): ...
def domain_types.Slack.deliver_channel_message(self, sender, channel: TaintSink[CrossBoundaryEgress], body: TaintSink[CrossBoundaryEgress]): ...
def domain_types.Message.__init__(self, sender, recipient: TaintSink[CrossBoundaryEgress], body: TaintSink[CrossBoundaryEgress]): ...
def domain_types.Web.publish(self, url: TaintSink[CrossBoundaryEgress], content: TaintSink[CrossBoundaryEgress]): ...

# ========== DATA_DESTRUCTION ==========
def domain_types.Inbox.remove_email(self, email_id: TaintSink[DataDestruction]): ...
def domain_types.CloudDrive.remove_file(self, file_id: TaintSink[DataDestruction]): ...
def domain_types.Calendar.remove_event(self, event_id: TaintSink[DataDestruction]): ...
def domain_types.Slack.expel_user(self, user: TaintSink[DataDestruction]): ...

# ========== IDENTITY_ADMIN ==========
def domain_types.Slack.enroll_user(self, user: TaintSink[IdentityAdmin]): ...
def domain_types.Slack.assign_channel(self, user: TaintSink[IdentityAdmin], channel): ...
def domain_types.CloudDriveFile.grant_share(self, email: TaintSink[IdentityAdmin], permission): ...

# ========== WRITE_MUTATE ==========
def domain_types.Calendar.add_event(self, event_id: TaintSink[WriteMutate], event: TaintSink[WriteMutate]): ...
def domain_types.Calendar.update_event(self, event_id: TaintSink[WriteMutate]): ...
def domain_types.CloudDrive.store_file(self, file_id: TaintSink[WriteMutate], filename: TaintSink[WriteMutate], content: TaintSink[WriteMutate]): ...
def domain_types.CloudDrive.write_to_file(self, file_id: TaintSink[WriteMutate], content: TaintSink[WriteMutate]): ...
def domain_types.UserAccount.change_info(self, first_name: TaintSink[WriteMutate], last_name: TaintSink[WriteMutate]): ...

# ========== CREDENTIAL_ACCESS ==========
def domain_types.UserAccount.change_password(self, new_password: TaintSink[CredentialAccess]): ...

# ========== EXTERNAL_INGESTION ==========
def domain_types.Web.fetch(self, url: TaintSink[ExternalIngestion]): ...

# ========== READ_PRIVATE ==========
def domain_types.Inbox.query_emails(self, query: TaintSink[ReadPrivate], sender): ...
def domain_types.Inbox.get_all_emails(self: TaintSink[ReadPrivate]): ...
def domain_types.Inbox.get_emails_by_status(self: TaintSink[ReadPrivate], status): ...
def domain_types.CloudDrive.retrieve_file(self, file_id: TaintSink[ReadPrivate]): ...
def domain_types.CloudDrive.find_files(self, query: TaintSink[ReadPrivate]): ...
def domain_types.CloudDrive.find_files_by_name(self, filename: TaintSink[ReadPrivate]): ...
def domain_types.CloudDrive.list_all_files(self: TaintSink[ReadPrivate]): ...
def domain_types.Slack.read_channel(self, channel: TaintSink[ReadPrivate]): ...
def domain_types.Slack.read_user_inbox(self, user: TaintSink[ReadPrivate]): ...
def domain_types.Slack.list_channels(self: TaintSink[ReadPrivate]): ...
def domain_types.Slack.list_users_in_channel(self, channel: TaintSink[ReadPrivate]): ...
def domain_types.Filesystem.read(self, file_path: TaintSink[ReadPrivate]): ...

# ========== READ_PUBLIC ==========
def domain_types.Hotels.query(self, city: TaintSink[ReadPublic]): ...
def domain_types.Hotels.get_prices(self, hotel_names: TaintSink[ReadPublic]): ...
def domain_types.Hotels.get_info(self, hotel_name: TaintSink[ReadPublic]): ...
def domain_types.Restaurants.query(self, city: TaintSink[ReadPublic]): ...
def domain_types.Restaurants.get_info(self, restaurant_names: TaintSink[ReadPublic]): ...
def domain_types.CarRental.query(self, city: TaintSink[ReadPublic]): ...
def domain_types.CarRental.get_info(self, company_name: TaintSink[ReadPublic]): ...
def domain_types.Flights.query(self, departure: TaintSink[ReadPublic], arrival: TaintSink[ReadPublic]): ...
def domain_types.BankAccount.get_recent_transactions(self, n: TaintSink[ReadPrivate]): ...
def domain_types.BankAccount.get_all_scheduled(self: TaintSink[ReadPrivate]): ...
def domain_types.Calendar.get_events_for_day(self, day: TaintSink[ReadPrivate]): ...
def domain_types.Calendar.search(self, query: TaintSink[ReadPrivate], date): ...
